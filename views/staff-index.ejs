<%- include("components/head", { pageTitle, extraStyles }) %>

<div class="m-grid m-grid--hor m-grid--root m-page">
  <%- include("components/header") %>
  <div class="m-grid__item m-grid__item--fluid m-grid m-grid--ver-desktop m-grid--desktop m-body">
    <%- include("components/sidebar", { navItems, activePath }) %>
    <div class="m-grid__item m-grid__item--fluid m-wrapper">
      <%- include("components/auth-context") %>
      <%- include("components/subheader", { title: "Nhân viên", subtitle: "CRUD nội bộ, scope theo cửa hàng và vai trò đăng nhập" }) %>

      <div class="m-content">
        <div class="m-portlet staff-page">
          <div class="m-portlet__body">
            <div class="staff-summary">
              <div class="staff-summary__card">
                <div class="staff-summary__label">Tong nhan vien</div>
                <div class="staff-summary__value" id="staffSummaryCount"><%= bootstrap.summary.count %></div>
              </div>
              <div class="staff-summary__card">
                <div class="staff-summary__label">Đang làm việc</div>
                <div class="staff-summary__value" id="staffSummaryActive"><%= bootstrap.summary.activeCount %></div>
              </div>
              <div class="staff-summary__card">
                <div class="staff-summary__label">Tạm khóa</div>
                <div class="staff-summary__value" id="staffSummaryInactive"><%= bootstrap.summary.inactiveCount %></div>
              </div>
            </div>

            <div class="staff-toolbar">
              <div class="staff-toolbar__group staff-toolbar__group--grow">
                <label class="staff-field">
                  <span class="staff-field__label">Tìm kiếm</span>
                  <input id="generalSearch" class="form-control m-input" type="text" placeholder="Tài khoản, họ tên, email, số điện thoại...">
                </label>

                <label class="staff-field">
                  <span class="staff-field__label">Tình trạng</span>
                  <select id="statusFilter" class="form-control m-input">
                    <option value="100">Tất cả</option>
                    <option value="1">Đang làm việc</option>
                    <option value="0">Tạm khóa</option>
                  </select>
                </label>

                <label class="staff-field">
                  <span class="staff-field__label">Cửa hàng</span>
                  <select id="shopFilter" class="form-control m-input" <%= canManageAllShops ? '' : 'disabled' %>>
                    <option value="0">Tất cả</option>
                    <% shopOptions.forEach((shop) => { %>
                      <option value="<%= shop.id %>"><%= shop.name %></option>
                    <% }) %>
                  </select>
                </label>

                <label class="staff-field staff-field--small">
                  <span class="staff-field__label">Mỗi trang</span>
                  <select id="perPageFilter" class="form-control m-input">
                    <option value="25">25</option>
                    <option value="50" selected>50</option>
                    <option value="100">100</option>
                  </select>
                </label>
              </div>

              <div class="staff-toolbar__group">
                <% if (canCreateStaff) { %>
                  <a href="/Staff/Create" class="btn btn-accent">Thêm mới</a>
                <% } %>
                <button id="btnReloadData" class="btn btn-secondary" type="button">Lấy dữ liệu</button>
              </div>
            </div>

            <div class="app-bulk-actions">
              <div id="staffSelectedInfo" class="app-table__selection">Đã chọn 0 dòng</div>
              <div class="app-bulk-actions__buttons">
                <button id="btnStaffBulkStatus" class="btn btn-secondary" type="button">Đổi trạng thái</button>
                <button id="btnStaffExport" class="btn btn-info" type="button">Export CSV</button>
                <% if (canDeleteStaff) { %>
                  <button id="btnStaffBulkDelete" class="btn btn-danger" type="button">Xóa đã chọn</button>
                <% } %>
              </div>
            </div>

            <div class="staff-table-wrap">
              <table class="table table-bordered table-hover staff-table">
                <thead>
                  <tr>
                    <th class="app-table__select-head">
                      <input id="staffSelectAll" class="app-table__checkbox" type="checkbox" aria-label="Chọn tất cả">
                    </th>
                    <th data-sort="shopName">Cửa hàng</th>
                    <th data-sort="username">Tài khoản</th>
                    <th data-sort="fullName">Họ tên</th>
                    <th>Email</th>
                    <th data-sort="phone">Điện thoại</th>
                    <th>Role</th>
                    <th data-sort="createdDate" class="text-center">Ngày tạo</th>
                    <th data-sort="status" class="text-center">Tình trạng</th>
                    <th>Chức năng</th>
                  </tr>
                </thead>
                <tbody id="staffTableBody">
                  <tr>
                    <td colspan="10" class="text-center text-muted">Đang tải dữ liệu...</td>
                  </tr>
                </tbody>
              </table>
            </div>

            <div class="staff-footer">
              <div>
                <div id="staffTableMeta" class="staff-footer__meta"></div>
              </div>
              <div id="staffPagination" class="staff-pagination"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include("components/flash") %>
<script>
  window.__STAFF_PAGE__ = {
    listUrl: "/staff/api/list",
    transferOptionsUrl: "/staff/api/transfer-options",
    deleteUrlBase: "/staff/api",
    bulkDeleteUrl: "/staff/api/bulk-delete",
    bulkStatusUrl: "/staff/api/bulk-status",
    canManageAllShops: <%= canManageAllShops ? 'true' : 'false' %>,
    canManagePermissions: <%= currentUser && currentUser.role === 'admin' ? 'true' : 'false' %>,
    canDeleteStaff: <%= canDeleteStaff ? 'true' : 'false' %>,
    defaultShopId: <%= canManageAllShops ? 0 : (currentUser ? currentUser.shopId : 0) %>
  };
</script>
<%- include("components/scripts", { extraScripts, inlineScripts }) %>
