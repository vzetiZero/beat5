<%- include("components/head", { pageTitle, extraStyles }) %>

<div class="m-grid m-grid--hor m-grid--root m-page">
  <%- include("components/header") %>
  <div class="m-grid__item m-grid__item--fluid m-grid m-grid--ver-desktop m-grid--desktop m-body">
    <%- include("components/sidebar", { navItems, activePath }) %>
    <div class="m-grid__item m-grid__item--fluid m-wrapper">
      <%- include("components/auth-context") %>
      <% const isCalendarPage = installmentPageMode === "calendar"; %>
      <% const subheaderTitle = isCalendarPage ? "Hợp đồng Đến Hạn Trả Góp" : "Trả góp"; %>
      <% const subheaderSubtitle = installmentViewOnlyMode
        ? "MAIN"
        : (isCalendarPage
          ? "Danh sách hợp đồng quá hạn và chậm trả góp cần theo dõi"
          : "Danh sách hợp đồng"); %>
      <%- include("components/subheader", { title: subheaderTitle, subtitle: subheaderSubtitle }) %>

      <div class="m-content installment-annam-page <%= isCalendarPage ? 'installment-annam-page--calendar' : 'installment-annam-page--list' %>">
        <% if (installmentViewOnlyMode) { %>
          <div class="alert alert-warning installment-annam-viewonly-banner" role="alert">
            Chế độ giao diện tĩnh đang bật cho mục Trả góp. Dữ liệu trên trang và popup đang dùng mock để rà giao diện, chưa đọc/ghi SQLite.
          </div>
        <% } %>
        <% if (isCalendarPage) { %>
          <div class="alert alert-info installment-annam-calendar-banner" role="alert">
            Theo dõi các hợp đồng cần xử lý tại một màn riêng. Danh sách này tự động lọc các hợp đồng <b>Quá hạn</b> và <b>Chậm trả góp</b>.
          </div>
        <% } %>

        <div class="m-portlet m-portlet--mobile">
          <div class="m-portlet__head">
            <div class="m-portlet__head-caption">
              <div class="m-portlet__head-title">
                <h3 class="m-portlet__head-text"><%= isCalendarPage ? "Hợp đồng Đến Hạn Trả Góp" : "Hợp đồng Trả góp" %></h3>
              </div>
            </div>
          </div>
          <div class="m-portlet__body">
            <div class="row">
              <% if (!isCalendarPage) { %>
                <div class="col-lg-12 col-xl-12 col-sm-12 col-12">
                  <div class="card installment-annam-cards">
                    <div class="row clearfix text-center">
                      <div class="m--margin-top-10 col-md-6" id="dvMoneyEndDate">
                        <div class="body bg-info text-light installment-annam-card installment-annam-card--cash">
                          <div>VỐN ĐANG CÓ THỰC TẾ <a class="installment-annam-reload" id="dashboardReloadLink" style="cursor:pointer;"><i class="flaticon-share m--font-danger" title="Reload dữ liệu"></i></a></div>
                          <h4 id="lbl_LoanPawn_MoneyEndDate">0</h4>
                        </div>
                      </div>
                      <div class="m--margin-top-10 col-md-6" id="dvMoneyInvestmentDisbursed">
                        <div class="body bg-info text-light installment-annam-card installment-annam-card--loan">
                          <span>TIỀN ĐÃ CHO VAY</span>
                          <h4 id="lbl_LoanPawn_MoneyInvestmentDisbursed">0</h4>
                        </div>
                      </div>
                      <div class="m--margin-top-10 col-md-6" id="dvMoneyInvestmentOutstanding">
                        <div class="body bg-info text-light installment-annam-card installment-annam-card--loan">
                          <span>TIỀN ĐANG CHO VAY</span>
                          <h4 id="lbl_LoanPawn_MoneyInvestmentOutstanding">0</h4>
                        </div>
                      </div>
                      <div class="m--margin-top-10 col-md-6" id="dvPrincipalOutstanding">
                        <div class="body bg-info text-light installment-annam-card installment-annam-card--loan">
                          <span>DƯ NỢ GỐC</span>
                          <h4 id="lbl_LoanPawn_PrincipalOutstanding">0</h4>
                        </div>
                      </div>
                      <div class="m--margin-top-10 col-md-4" id="dvInterestExpected">
                        <div class="body m--bg-brand text-light installment-annam-card installment-annam-card--revenue">
                          <span>LÃI DỰ KIẾN</span>
                          <h4 id="lbl_LoanPawn_InterestExpected">0</h4>
                        </div>
                      </div>
                      <div class="m--margin-top-10 col-md-4" id="dvInterestEarned">
                        <div class="body bg-success text-light installment-annam-card installment-annam-card--paid">
                          <span>LÃI ĐÃ THU</span>
                          <h4 id="lbl_LoanPawn_InterestEarned">0</h4>
                        </div>
                      </div>
                      <div class="m--margin-top-10 col-md-4" id="dvContractSummary">
                        <div class="body bg-success text-light installment-annam-card installment-annam-card--contract">
                          <span>TỔNG HỢP ĐỒNG</span>
                          <h4 id="lbl_LoanPawn_TotalContracts">0</h4>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              <% } %>

              <div class="col-lg-12 col-xl-12 col-sm-12 col-12 m--align-left m--margin-top-10 installment-annam-toolbar">
                <% if (!isCalendarPage) { %>
                  <button class="btn btn-accent m-btn m-btn--custom m-btn--icon m-btn--air btn-sm" id="btnModalCreate" type="button">
                    <span>Thêm mới</span>
                  </button>
                <% } else { %>
                  <a class="btn btn-secondary m-btn m-btn--custom m-btn--icon m-btn--air btn-sm" href="/Installment/Index/">
                    <span>Xem toàn bộ hợp đồng</span>
                  </a>
                <% } %>
                <button class="btn btn-success m-btn m-btn--custom m-btn--icon m-btn--air btn-sm" type="button" id="btnExportVisible">Xuất CSV</button>
                <% if (canImportInstallment && !isCalendarPage) { %>
                  <button class="btn btn-addNew m-btn m-btn--custom m-btn--icon m-btn--air btn-sm" type="button" id="btnImportExcel">Thêm DL Mới Excel</button>
                <% } %>
                <% if (canSelectShop) { %>
                  <button class="btn btn-secondary m-btn m-btn--custom m-btn--icon m-btn--air btn-sm" type="button" id="btnViewAllShops">Tất cả cửa hàng</button>
                <% } %>
                <button class="btn btn-warning m-btn m-btn--custom m-btn--icon m-btn--air btn-sm" type="button" id="btnTomorrowDueCheck" title="Xem các hợp đồng đến kỳ thanh toán ngày mai">
                  <span><i class="fa fa-calendar-plus-o"></i><span><%= isCalendarPage ? 'Ngày Mai' : 'Kiểm tra ngày mai' %></span></span>
                </button>
                <input id="excelFileInput" type="file" accept=".xlsx,.xls,.csv" hidden>
              </div>

              <div class="col-lg-2 col-xl-2 col-sm-6 col-12 m--margin-top-10">
                <div class="m-input-icon m-input-icon--right">
                  <input class="form-control m-input" id="generalSearch" placeholder="Tìm kiếm mã HĐ, Tên KH..." type="text">
                  <span class="m-input-icon__icon m-input-icon__icon--right"><span><i class="la la-search"></i></span></span>
                </div>
              </div>

              <div class="col-lg-2 col-xl-2 col-sm-6 col-6 m--margin-top-10 installment-annam-filter-date">
                <div class="m-input-icon m-input-icon--right">
                  <input type="date" class="form-control m-input" id="txtFromDate" placeholder="Từ ngày">
                  <span class="m-input-icon__icon m-input-icon__icon--right"><span><i class="la la-calendar text-black"></i></span></span>
                </div>
              </div>

              <div class="col-lg-2 col-xl-2 col-sm-6 col-6 m--margin-top-10 installment-annam-filter-date">
                <div class="m-input-icon m-input-icon--right">
                  <input type="date" class="form-control m-input" id="txtToDate" placeholder="Đến ngày">
                  <span class="m-input-icon__icon m-input-icon__icon--right"><span><i class="la la-calendar text-black"></i></span></span>
                </div>
              </div>

              <div class="col-lg-2 col-xl-2 col-sm-6 col-6 m--margin-top-10">
                <div class="dropdown-container">
                  <select class="custom-select" id="m-search-loanTime">
                    <option value="0">Tất cả ngày</option>
                    <% bootstrap.availableLoanDays.forEach((loanDay) => { %>
                      <option value="<%= loanDay %>"><%= loanDay %> ngày</option>
                    <% }) %>
                  </select>
                </div>
              </div>

              <div class="col-lg-2 col-xl-2 col-sm-6 col-6 m--margin-top-10">
                <div class="dropdown-container">
                  <select class="custom-select" id="m-search-status">
                    <option value="0">Tất cả hợp đồng</option>
                    <% bootstrap.availableStatuses.forEach((status) => { %>
                      <option value="<%= status.value || status.label %>"><%= status.label %></option>
                    <% }) %>
                  </select>
                </div>
              </div>

              <div class="col-lg-2 col-xl-2 col-sm-6 col-12 m--margin-top-10">
                <div class="dropdown-container">
                  <select class="custom-select" id="shopFilter" <%= canSelectShop ? '' : 'disabled' %>>
                    <option value="0">Tất cả cửa hàng</option>
                    <% shopOptions.forEach((shop) => { %>
                      <option value="<%= shop.id %>" <%= defaultShopId === shop.id ? 'selected' : '' %>><%= shop.name %></option>
                    <% }) %>
                  </select>
                </div>
              </div>

              <div class="col-lg-1 col-xl-1 col-sm-6 col-6 m--margin-top-10">
                <button class="btn btn-info m-btn m-btn--air installment-annam-action-btn" id="btnGetData" type="button">
                  <span><i class="fa fa-search"></i><span>Tìm kiếm</span></span>
                </button>
              </div>

              <div class="col-lg-1 col-xl-1 col-sm-6 col-6 m--margin-top-10">
                <button class="btn btn-secondary m-btn m-btn--air installment-annam-action-btn" id="btnResetSearch" type="button">
                  <span><i class="fa fa-refresh"></i><span>Reset</span></span>
                </button>
              </div>
              <div class="col-md-12 m--margin-top-10">
                <div class="installment-annam-status-row" id="installmentStatusSummary">
                  <% bootstrap.statusSummary.forEach((item) => { %>
                    <span class="m-badge m-badge--wide installment-annam-summary-pill"><%= item.statusText %>: <b><%= item.count %></b></span>
                  <% }) %>
                </div>
              </div>

              <div class="col-md-12 m--margin-top-10">
                <div class="installment-annam-scroll-hint">Kéo thanh cuộn ngang bên dưới để xem thêm cột khi bảng quá rộng.</div>
                <div id="dtInstallment" class="installment-annam-table-wrap <%= isCalendarPage ? 'installment-annam-table-wrap--calendar' : '' %>">
                  <div class="m_datatable m-datatable m-datatable--default table table-bordered table-hover m-datatable--loaded">
                    <table class="m-datatable__table installment-annam-table <%= isCalendarPage ? 'installment-annam-table--calendar' : '' %>">
                      <thead class="m-datatable__head">
                        <tr class="m-datatable__row">
                          <th data-sort="rowNumber" class="m-datatable__cell--center m-datatable__cell"><span style="width: 40px;">#</span></th>
                          <th data-sort="contractCode" class="m-datatable__cell"><span style="width: 90px;">Mã HĐ</span></th>
                          <th data-sort="customerRef" class="m-datatable__cell"><span style="width: 170px;">Khách hàng</span></th>
                          <th data-sort="loanPackage" class="m-datatable__cell--right m-datatable__cell"><span style="width: 120px;">Tiền giao khách</span></th>
                          <th data-sort="installerName" class="m-datatable__cell--left m-datatable__cell"><span style="width: 120px;">Nhân Viên</span></th>
                          <th data-sort="loanDate" class="m-datatable__cell--center m-datatable__cell"><span style="width: 150px;">Thời gian</span></th>
                          <th data-sort="paidBefore" class="m-datatable__cell--right m-datatable__cell"><span style="width: 120px;">Tiền đã đóng</span></th>
                          <th data-sort="installmentAmount" class="m-datatable__cell--right m-datatable__cell"><span style="width: 100px;">Tiền 1 kỳ</span></th>
                          <th data-sort="remainingMoney" class="m-datatable__cell--right m-datatable__cell"><span style="width: 120px;">Còn phải đóng</span></th>
                          <th data-sort="statusText" class="m-datatable__cell--center m-datatable__cell"><span style="width: 110px;">Tình trạng</span></th>
                          <th data-sort="paymentDay" class="m-datatable__cell--center m-datatable__cell"><span style="width: 100px;">Ngày phải đóng</span></th>
                          <th class="m-datatable__cell installment-annam-sticky-action"><span style="width: 190px;">Chức năng</span></th>
                        </tr>
                      </thead>
                      <tbody class="m-datatable__body" id="installmentTableBody">
                        <tr class="m-datatable__row"><td colspan="12" class="installment-annam-empty">Đang tải dữ liệu...</td></tr>
                      </tbody>
                    </table>
                    <div class="m-datatable__pager m-datatable--paging-loaded clearfix">
                      <ul class="m-datatable__pager-nav" id="installmentPagination"></ul>
                      <div class="m-datatable__pager-info">
                        <div class="btn-group bootstrap-select m-datatable__pager-size installment-annam-pager-size">
                          <select class="selectpicker m-datatable__pager-size" id="perPageFilter" title="Select page size" data-width="70px">
                            <option value="10">10</option>
                            <option value="20">20</option>
                            <option value="30">30</option>
                            <option value="50" selected>50</option>
                            <option value="100">100</option>
                          </select>
                        </div>
                        <span class="m-datatable__pager-detail" id="installmentPagerDetail">Tổng số 0 bản ghi - Trang 0/0</span>
                      </div>
                    </div>
                  </div>
                </div>
                <% if (isCalendarPage) { %>
                  <div class="installment-annam-calendar-footnote">
                    Màn này đang dùng cùng popup `Đóng tiền`, `Cập nhật ngày đóng`, `Sửa hợp đồng` và `Xóa` như danh sách Trả góp để giữ một luồng CRUD thống nhất.
                  </div>
                <% } %>
              </div>
            </div>
          </div>
        </div>

        <div class="modal fade" id="modal_details_pawn" tabindex="-1" role="dialog" aria-hidden="true">
          <div class="modal-dialog modal-xl" role="document">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title" id="model_pawn_header">Bảng chi tiết Hợp đồng</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close" id="btnCloseModalPawn"><span aria-hidden="true">×</span></button>
              </div>
              <div class="modal-body">
                <input type="hidden" id="hddLoanID" value="">
                <input type="hidden" id="hddCustomerID" value="">
                <input type="hidden" id="hddTotalMoneyCurrent" value="">
                <input type="hidden" name="hddNotePayment" id="hddNotePayment" value="0">
                <div class="m-form m-form--fit m-form--label-align-right">
                  <div class="m-portlet__body">
                    <div class="row">
                      <div class="col-md-6">
                        <table class="table table-hover table-bordered">
                          <tbody>
                            <tr id="trCusName">
                              <td colspan="3">
                                <span class="text-danger font-weight-bold" id="lblCusName"></span> <span id="lblCusPhone"></span>
                                <span id="lblCusAddress"></span>
                                <span id="lblAff"></span>
                              </td>
                            </tr>
                            <tr><td><span class="font-weight-bold">Trả Góp</span></td><td colspan="2" align="right"><span id="lblTotalMoney"></span> VNĐ</td></tr>
                            <tr><td><span class="font-weight-bold">Nhân Viên</span></td><td colspan="2" align="right"><span id="lblStrRate"></span></td></tr>
                            <tr><td><span class="font-weight-bold">Họ từ ngày</span></td><td align="right"><span id="lblFromDate"></span></td><td align="right"><span id="lblToDate"></span></td></tr>
                            <tr><td><span class="font-weight-bold">Trạng thái</span></td><td colspan="2" align="right"><span id="lblStatus"></span></td></tr>
                          </tbody>
                        </table>
                      </div>
                      <div class="col-md-6">
                        <table class="table table-hover table-bordered">
                          <tbody>
                            <tr><td><span class="font-weight-bold">Số tiền giao khách</span></td><td colspan="2" align="right"><span id="lblTotalMoneyReceived"></span> VNĐ</td></tr>
                            <tr><td><span class="font-weight-bold">Tổng tiền phải đóng</span></td><td colspan="2" align="right"><span id="lblTotalMoneyPayment" class="text-danger font-weight-bold"></span> VNĐ</td></tr>
                            <tr><td><span class="font-weight-bold">Đã đóng được</span></td><td colspan="2" align="right"><span id="lblPaymentMoney"></span> VNĐ</td></tr>
                            <tr><td><span class="font-weight-bold">Còn lại phải đóng</span></td><td colspan="2" align="right"><span id="lblTotalMoneyCurrent" class="text-danger font-weight-bold"></span> VNĐ</td></tr>
                            <tr><td><span class="font-weight-bold">Tổng lãi</span></td><td colspan="2" align="right"><span id="lblTotalInterest"></span> VNĐ</td></tr>
                          </tbody>
                        </table>
                      </div>
                    </div>

                    <div class="row">
                      <div class="col-md-12">
                        <div class="m-portlet__head">
                          <div class="m-portlet__head-tools">
                            <ul class="nav nav-tabs m-tabs-line m-tabs-line--primary m-tabs-line--2x" id="tabs" role="tablist">
                              <li class="nav-item m-tabs__item" id="item_donglai"><a class="nav-link m-tabs__link active" data-toggle="tab" href="#m_tab_lichdongtien"><i class="la la-money"></i>Lịch đóng tiền</a></li>
                              <li class="nav-item m-tabs__item m-nav" id="item_chuocdo"><a class="nav-link m-tabs__link" data-toggle="tab" href="#m_tab_donghopdongvayho"><i class="fa fa-money"></i>Đóng HĐ</a></li>
                              <li class="nav-item m-tabs__item m-nav" id="item_denhan"><a class="nav-link m-tabs__link" data-toggle="tab" href="#m_tab_denhanhthanhtoan"><img src="/public/assets/pay.svg" alt="Pay" style="width:16px; height:16px; margin-right:5px; vertical-align: middle;"/>Đến Hạn Thanh Toán</a></li>
                              <li class="nav-item m-tabs__item m-nav" id="item_lichsu"><a class="nav-link m-tabs__link" data-toggle="tab" href="#m_tab_lichsu"><i class="la la-commenting"></i>Lịch sử</a></li>
                            </ul>
                          </div>
                          <div class="m-portlet__head-tools installment-annam-detail-tools">
                            <button id="btnTomorrowInstallmentsInline" class="btn btn-warning m-btn m-btn--air" type="button" title="Xem các hợp đồng đến kỳ thanh toán ngày mai">
                              <i class="fa fa-calendar-plus-o"></i>
                              <span>Ngày Mai</span>
                            </button>
                          </div>
                        </div>
                      </div>
                    </div>
                    <div class="tab-content">
                      <div class="tab-pane active" id="m_tab_lichdongtien">
                        <br>
                        <div><i class="m-portlet__head-text"><i class="fa fa-align-justify"></i> Lịch đóng tiền</i></div>
                        <div class="m-form__seperator m-form__seperator--dashed m-form__seperator--space"></div>
                        <div class="alert alert-info" role="alert" id="installmentPaymentSummary">
                          Kỳ hiện tại: <b id="lblCurrentPeriodLabel">-</b>.
                          Cần đóng <b id="lblCurrentPeriodDue">0</b> VNĐ,
                          đã đóng <b id="lblCurrentPeriodPaid">0</b> VNĐ,
                          còn thiếu <b id="lblCurrentPeriodRemaining">0</b> VNĐ.
                        </div>
                        <div class="installment-annam-inline-note">Lưu ý: Đối với điện thoại iOS, vui lòng vuốt 2 bên lịch để xem đầy đủ.</div>
                        <div class="table-responsive">
                          <table id="tbl_DongTien_list" class="table table-bordered m-table m-table--head-bg-gray table-hover">
                            <thead>
                              <tr>
                                <th width="80px" class="text-center">STT</th>
                                <th colspan="3" class="text-center">Ngày</th>
                                <th width="150px" class="text-center">Tiền họ</th>
                                <th class="text-center" style="padding:0 30px 10px;">Đã thu kỳ</th>
                                <th class="text-center" style="padding:0 40px 10px;">Ngày giao dịch</th>
                                <th class="text-center" style="padding:0 40px 10px;">Tiền Còn Phải Đóng</th>
                                <th class="text-center"></th>
                                <th class="text-center">Trạng Thái</th>
                              </tr>
                            </thead>
                            <tbody></tbody>
                          </table>
                        </div>
                      </div>

                      <div class="tab-pane" id="m_tab_donghopdongvayho">
                        <div class="row">
                          <div class="col-lg-12 col-sm-12 col-12 col-form-label font-weight-bold" id="dvDone" style="display:none;">Hợp đồng này đã hoàn thành. Bạn có thể đánh dấu đóng hợp đồng.</div>
                          <div class="col-lg-9" id="dvPending"><span class="font-weight-bold">Chú ý:</span><br>Số tiền còn phải đóng:&nbsp;&nbsp;<span class="text-danger font-weight-bold"><label id="lblDongHD_TotalMoneyCurrent">0</label> VNĐ</span><br></div>
                          <div class="col-lg-12 col-sm-12 col-12 col-form-label font-weight-bold"><button type="button" id="btnDongHopDongVayHo" class="btn btn-sm btn-primary m-btn--air btn-secondary"><i class="fa fa-check"></i> Đóng hợp đồng</button></div>
                        </div>
                      </div>

                      <div class="tab-pane" id="m_tab_lichsu">
                        <h6><i class="m-portlet__head-text"><i class="fa fa-history"></i> Lịch sử hợp đồng</i></h6>
                        <div class="m-form__seperator m-form__seperator--dashed m-form__seperator--space"></div>
                        <div class="table-responsive">
                          <table class="table table-bordered table-hover">
                            <thead><tr><th>Thời gian</th><th>Người thao tác</th><th>Hành động</th><th>Ghi chú</th></tr></thead>
                            <tbody id="installmentHistoryTableBody"></tbody>
                          </table>
                        </div>
                      </div>

                      <div class="tab-pane" id="m_tab_denhanhthanhtoan">
                        <br>
                        <div><i class="m-portlet__head-text"><i class="fa fa-calendar"></i> Đến Hạn Thanh Toán</i></div>
                        <div class="m-form__seperator m-form__seperator--dashed m-form__seperator--space"></div>
                        <div class="alert alert-info" role="alert">
                          <i class="la la-info-circle"></i> Danh sách các hợp đồng sắp đến hạn thanh toán hoặc đã quá hạn.
                        </div>
                        <div class="table-responsive">
                          <table id="tbl_DuePayment_list" class="table table-bordered m-table m-table--head-bg-gray table-hover">
                            <thead>
                              <tr>
                                <th width="80px" class="text-center">STT</th>
                                <th class="text-center">Mã HĐ</th>
